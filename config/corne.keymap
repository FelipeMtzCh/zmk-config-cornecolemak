 * SPDX-License-Identifier: MIT
 *
 * Optimized Corne Keymap — Colemak-DH (Modern)
 * - Capa 0: COLEMAK-DH con Homerow Mods
 * - Capa 1: Símbolos (tap = apertura, double-tap = cierre) + Numpad derecho
 * - Capa 2: Config RGB, Bluetooth, Multimedia, Combos (Ctrl+C, Ctrl+V, Ctrl+F, Ctrl+Shift+F4)
 *
 * Homerow mods (mano izquierda):
 *   A = GUI  |  R = ALT  |  S = CTRL  |  T = SHIFT
 * Homerow mods (mano derecha):
 *   N = SHIFT  |  E = CTRL  |  I = ALT  |  O = GUI
 *
 * Colemak-DH layout (vs Colemak: D baja a fila inferior, H sube a fila home izq,
 *                                 M sube a fila home der, B y X se reorganizan):
 *   Q  W  F  P  B     J  L  U  Y  ;
 *   A  R  S  T  G     M  N  E  I  O  '
 *   Z  X  C  D  V     K  H  ,  .  /
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

/* ─── Configuración global de hold-tap ─── */

&mt {
    flavor = "tap-preferred";
    tapping-term-ms = <200>;
    quick-tap-ms = <125>;
    require-prior-idle-ms = <100>;
};

&led_strip { chain-length = <27>; };

/ {
    /* ═══════════════════════════════════════
       MACROS
       ═══════════════════════════════════════ */

    macros {
        /* Macro original: escribe /calificacion */

        term: term {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LC(LA(T))>;
            label = "TERMINAL";
        };

        /* Símbolos de apertura */

        m_paren_o: m_paren_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LPAR>;
            label = "M_PAREN_O";
        };

        m_brack_o: m_brack_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LBKT>;
            label = "M_BRACK_O";
        };

        m_brace_o: m_brace_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LBRC>;
            label = "M_BRACE_O";
        };

        m_angle_o: m_angle_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LT>;
            label = "M_ANGLE_O";
        };

        m_dquot_o: m_dquot_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp DQT>;
            label = "M_DQUOT_O";
        };

        m_squot_o: m_squot_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SQT>;
            label = "M_SQUOT_O";
        };

        m_grave_o: m_grave_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp GRAVE>;
            label = "M_GRAVE_O";
        };

        m_tilde_o: m_tilde_o {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp TILDE>;
            label = "M_TILDE_O";
        };

        /* Símbolos de cierre */

        m_paren_c: m_paren_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RPAR>;
            label = "M_PAREN_C";
        };

        m_brack_c: m_brack_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RBKT>;
            label = "M_BRACK_C";
        };

        m_brace_c: m_brace_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RBRC>;
            label = "M_BRACE_C";
        };

        m_angle_c: m_angle_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp GT>;
            label = "M_ANGLE_C";
        };

        m_dquot_c: m_dquot_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp DQT>;
            label = "M_DQUOT_C";
        };

        m_squot_c: m_squot_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SQT>;
            label = "M_SQUOT_C";
        };

        m_grave_c: m_grave_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp GRAVE>;
            label = "M_GRAVE_C";
        };

        m_tilde_c: m_tilde_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp TILDE>;
            label = "M_TILDE_C";
        };

        zendesk_mac: zendesk_mac {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SLASH &kp F &kp E &kp L &kp I &kp P &kp E>;
            label = "ZENDESK_MAC";
        };
    };

    /* ═══════════════════════════════════════
       BEHAVIORS — Double-tap para símbolos
       tap  = símbolo de apertura
       hold (o double-tap ≤200 ms) = cierre
       ═══════════════════════════════════════ */

    behaviors {
        /*  ( → )  */

        td_paren: td_paren {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_paren_o>, <&m_paren_c>;
        };

        /*  [ → ]  */

        td_brack: td_brack {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_brack_o>, <&m_brack_c>;
        };

        /*  { → }  */

        td_brace: td_brace {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_brace_o>, <&m_brace_c>;
        };

        /*  < → >  */

        td_angle: td_angle {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_angle_o>, <&m_angle_c>;
        };

        /*  " → "  */

        td_dquot: td_dquot {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_dquot_o>, <&m_dquot_c>;
        };

        /*  ' → '  */

        td_squot: td_squot {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_squot_o>, <&m_squot_c>;
        };

        /* ` → ` */

        td_grave: td_grave {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_grave_o>, <&m_grave_c>;
        };

        /* ~ → ~ */

        td_tilde: td_tilde {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&m_tilde_o>, <&m_tilde_c>;
        };
    };

    /* ═══════════════════════════════════════
       KEYMAP
       ═══════════════════════════════════════ */

    keymap {
        compatible = "zmk,keymap";

        /* ───────────────────────────────────
           CAPA 0 — Base COLEMAK-DH + Homerow Mods
           ───────────────────────────────────
           Colemak-DH layout:
             Q  W  F  P  B  |  J  L  U  Y  ;
             A  R  S  T  G  |  M  N  E  I  O  '
             Z  X  C  D  V  |  K  H  ,  .  /

           Homerow mods (mano izquierda):
             A = GUI  |  R = ALT  |  S = CTRL  |  T = SHIFT
           Homerow mods (mano derecha):
             N = SHIFT  |  E = CTRL  |  I = ALT  |  O = GUI

           Pulgares:
             [GUI]  [MO1/ESC]  [Space]  |  [Enter]  [MO2]  [Del]
        ─────────────────────────────────── */

        Colemak-DH {
            display-name = "Colemak-DH";
            bindings = <
&kp GRAVE   &kp Q       &kp W       &kp F        &kp P         &kp B        &kp J      &kp L         &kp U        &kp Y       &kp SEMI    &kp BSPC
&caps_word  &mt LGUI A  &mt LALT R  &mt LCTRL S  &mt LSHIFT T  &kp G        &kp M      &mt RSHIFT N  &mt RCTRL E  &mt RALT I  &mt RGUI O  &kp SQT
&term       &kp Z       &kp X       &kp C        &kp D         &kp V        &kp K      &kp H         &kp COMMA    &kp DOT     &kp FSLH    &kp TAB
                                    &kp LGUI     &lt 1 ESC     &kp SPACE    &kp ENTER  &mo 2         &kp DELETE
            >;
        };

        /* ───────────────────────────────────
           CAPA 1 — Símbolos (izq) + Numpad (der)
        ─────────────────────────────────── */

        Sym-Num {
            display-name = "Sym/Num";
            bindings = <
&td_grave  &td_tilde  &kp EXCL   &kp AT     &kp HASH   &kp DOLLAR      &kp KP_MULTIPLY  &kp N7  &kp N8      &kp N9  &kp KP_SLASH  &kp BSPC
&trans     &td_paren  &td_brack  &td_brace  &td_angle  &td_dquot       &kp KP_MINUS     &kp N4  &kp N5      &kp N6  &kp KP_PLUS   &kp ENTER
&trans     &kp UNDER  &kp MINUS  &kp EQUAL  &kp PLUS   &zendesk_mac    &kp N0           &kp N1  &kp N2      &kp N3  &kp DOT       &kp TAB
                                 &kp LGUI   &trans     &kp SPACE       &kp ENTER        &trans  &kp DELETE
            >;
        };

        /* ───────────────────────────────────
           CAPA 2 — Config / Media / Combos
        ─────────────────────────────────── */

        Config {
            display-name = "Config";
            bindings = <
&kp ESC     &kp F2           &kp F3                          &kp F4                           &kp F5                             &kp F11                              &kp C_VOLUME_DOWN  &kp C_VOLUME_UP  &kp UP      &trans          &kp C_MUTE         &kp DELETE
&kp LSHIFT  &rgb_ug RGB_TOG  &rgb_ug RGB_COLOR_HSB(46,0,40)  &rgb_ug RGB_COLOR_HSB(42,42,35)  &rgb_ug RGB_COLOR_HSB(200,100,50)  &rgb_ug RGB_COLOR_HSB(116,100,50)    &kp LC(LS(LEFT))   &kp LEFT         &kp DOWN    &kp RIGHT       &kp LC(LS(RIGHT))  &kp PG_UP
&kp LCTRL   &bt BT_CLR       &bt BT_SEL 0                    &bt BT_SEL 1                     &bt BT_SEL 2                       &bt BT_SEL 3                         &kp LC(C)          &kp LC(V)        &kp LC(F)   &kp LC(LS(F4))  &kp PSCRN          &kp PG_DN
                                                             &kp LGUI                         &trans                             &kp C_PP                             &kp C_NEXT         &trans           &kp C_PREV
            >;
        };
    };
};
